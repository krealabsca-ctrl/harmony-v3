# .env.ejemplo — Variables de entorno para Harmony v3
#
# INSTRUCCIONES:
#   1. Copia este archivo a /opt/harmony/.env en el servidor
#   2. Completa todos los valores marcados con <...>
#   3. Ejecuta: chmod 600 /opt/harmony/.env && chown harmony:harmony /opt/harmony/.env
#   4. NUNCA subas el .env real a Git — ya está en .gitignore

# Entorno de ejecución
APP_ENV=production
PORT=8080

# URL pública del frontend (debe coincidir exactamente con tu dominio)
FRONTEND_URL=https://harmony.tuempresa.com

# PostgreSQL — Base de datos principal del sistema
DB_HOST=localhost
DB_PORT=5432
DB_USER=harmony
DB_PASS=<contraseña_segura_postgresql>
DB_SSLMODE=disable

# JWT — Seguridad de sesiones
# Genera con: openssl rand -hex 32
JWT_SECRET=<genera_con_openssl_rand_-hex_32>
JWT_EXPIRY_HOURS=24

# Anthropic Claude (para el bot de IA)
ANTHROPIC_KEY=sk-ant-api03-<tu_api_key>

# Redis (cola de trabajos asíncronos)
REDIS_URL=redis://localhost:6379

# Directorio de archivos subidos por usuarios
UPLOADS_DIR=/opt/harmony/uploads
