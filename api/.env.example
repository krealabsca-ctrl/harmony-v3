# ============================================================
# Harmony v3 API — Variables de entorno
# Copiar a .env y ajustar valores
# ============================================================

PORT=8080
APP_ENV=development
APP_KEY=change-this-to-a-random-32-char-string

# Base de datos (sistema)
DB_HOST=localhost
DB_PORT=5432
DB_USER=harmony
DB_PASS=harmony_secret
DB_NAME=harmony_system
DB_SSLMODE=disable

# Redis (Asynq queues)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRY_HOURS=24

# Frontend (CORS)
FRONTEND_URL=http://localhost:3000

# Azure Storage
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONNECTION_STRING=

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=
